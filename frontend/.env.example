# Vercel / preview / production builds — set in Vercel Project → Environment Variables
# Full API base including /api (no trailing slash after /api)
VITE_API_URL=https://your-service.up.railway.app/api

# Railway (same API host): ALLOWED_ORIGINS + FRONTEND_URL must include this Vercel app origin;
# COOKIE_CROSS_SITE=true when the SPA is on Vercel and the API on Railway.

# Optional: Socket.IO origin (no path). If unset, derived from VITE_API_URL in prod.
# VITE_WS_URL=wss://your-service.up.railway.app

# Optional: prod fallback when VITE_API_URL is missing at build time (forks, local prod)
# VITE_DEFAULT_API_URL=https://your-service.up.railway.app/api

# Local dev only — Vite proxy /api and /static to this backend origin (no /api suffix)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:5000

# Alternative: VITE_API_URL=http://127.0.0.1:5000/api — /api is stripped for the proxy target
