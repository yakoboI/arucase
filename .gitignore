# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python (legacy - keeping for reference)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Database files (keep structure, ignore actual data)
*.db
*.sqlite
*.sqlite3
# Keep SQL backups in data/backups/ but ignore if too large
# data/backups/*.sql

# Logs
logs/
*.log

# Environment variables
.env
.env.local
.env.production
.env.development

# Build outputs
dist/
build/
.next/
out/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Railway
.railway/

# Uploads (keep structure, ignore user-uploaded files)
static/uploads/*
!static/uploads/.gitkeep

# Admin photos source — committed to repo so they can be copied to the
# Railway persistent volume (/app/admin-photos) on deployment.
!backend/admin-photos-source/
!backend/admin-photos-source/*.png

# PostgreSQL dumps (from backend/scripts/backupDatabase.js)
backend/backups/

# Temporary files
*.tmp
*.temp
.cache/

# Markdown — keep out of version control (local docs only).
*.md
**/temp_*.js
temp_*.js
backend/auto_login.html

# Test / tooling (not needed to run app)
coverage/
.nyc_output/
.turbo/
*.lcov
