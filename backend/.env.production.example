# Production Environment Variables for Enhanced Security
# Copy this to .env.production and update values

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database
PGHOST=your-railway-host.railway.app
PGPORT=5432
PGUSER=your-username
PGPASSWORD=your-password
PGDATABASE=your-database

# JWT Security (CRITICAL - Use strong, unique secrets)
JWT_SECRET_KEY=your-super-secure-256-bit-jwt-secret-key-here-minimum-32-characters
JWT_ACCESS_TOKEN_EXPIRES=900  # 15 minutes in seconds
JWT_REFRESH_SECRET=your-different-super-secure-refresh-token-secret-key-here

# Rate Limiting
RATE_LIMIT_MAX=500  # Maximum requests per 15 minutes per IP
DB_MAX_CONCURRENT_QUERIES=80  # Database query limit (should be < pool max)
STATEMENT_TIMEOUT_MS=60000  # 60 seconds max query time

# Connection Pooling
POOL_MAX=100  # Maximum database connections

# CORS Security
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com,https://admin.yourdomain.com

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Application
NODE_ENV=production
PORT=5000

# Production Backend URL (for static assets in PDF generation)
RAILWAY_PUBLIC_URL=https://arucase-production.up.railway.app

# Security Headers
# These are automatically configured but can be overridden if needed
