# Production Environment Variables for Enhanced Security
# Copy this to .env.production and update values

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database
PGHOST=your-railway-host.railway.app
PGPORT=5432
PGUSER=your-username
PGPASSWORD=your-password
PGDATABASE=your-database

# Required when initDatabase runs seedAdminUser (first deploy / reset)
SEED_ADMIN_PASSWORD=your-strong-bootstrap-password

# JWT Security (CRITICAL - Use strong, unique secrets)
JWT_SECRET_KEY=your-super-secure-256-bit-jwt-secret-key-here-minimum-32-characters
JWT_ACCESS_TOKEN_EXPIRES=900  # 15 minutes in seconds
JWT_REFRESH_SECRET=your-different-super-secure-refresh-token-secret-key-here

# Rate Limiting
RATE_LIMIT_MAX=500  # Maximum requests per 15 minutes per IP
DB_MAX_CONCURRENT_QUERIES=80  # Database query limit (should be < pool max)
STATEMENT_TIMEOUT_MS=60000  # 60 seconds max query time

# Connection Pooling
POOL_MAX=100  # Maximum database connections

# CORS: CSV of allowed browser Origins (no trailing slash). Include production + preview URLs, or use flag below.
ALLOWED_ORIGINS=https://arucase.vercel.app
# Primary SPA origin (merged into CORS allowlist; also used by hosting helpers)
FRONTEND_URL=https://arucase.vercel.app
# Vercel app → Railway API: cookies must be cross-site (SameSite=None; Secure)
COOKIE_CROSS_SITE=true
# Equivalent to COOKIE_CROSS_SITE (alias only — set one, not both required)
# CROSS_ORIGIN_COOKIES=true

# Deploy sync: Vercel must set VITE_API_URL=https://<this-service>/api (same host as RAILWAY_PUBLIC_URL origin + /api).
# If you use preview URLs and do not list each in ALLOWED_ORIGINS, set CORS_ALLOW_VERCEL_PREVIEWS=true on Railway.

# Optional: allow any https://*.vercel.app Origin (preview deployments) without listing each URL
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Listen address (0.0.0.0 for Railway/container; default in code is 0.0.0.0)
# HOST=0.0.0.0

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Application
NODE_ENV=production
PORT=5000

# Production Backend URL (for static assets in PDF generation)
RAILWAY_PUBLIC_URL=https://arucase-production.up.railway.app

# Security Headers
# These are automatically configured but can be overridden if needed

# Optional: one-off maintenance scripts (never commit real URLs/passwords)
# LOCAL_DATABASE_URL=postgresql://...
# RAILWAY_DATABASE_URL=postgresql://...
