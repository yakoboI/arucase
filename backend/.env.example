# Copy to backend/.env — never commit .env

# App + database (required for server)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Required for initDatabase / seedAdminUser (choose a strong password)
SEED_ADMIN_PASSWORD=

# Optional: one-off scripts
# LOCAL_DATABASE_URL=postgresql://...
# RAILWAY_DATABASE_URL=postgresql://...
# MYSQL_PASSWORD=           # legacy MySQL → PG migration only
# ADMIN_PASSWORD=           # backend/scripts/createAdmin.js
# TEST_LOGIN_PASSWORD=      # backend/test_auth_flow.js, test_august_api_direct.js
# DEV_AUTO_LOGIN_JWT=       # backend/auto_login_fix.js (regenerate after running script)
