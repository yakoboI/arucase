# Copy to backend/.env — never commit .env

# App + database (required for server)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Optional: require valid TLS certificate when using SSL (default false for many managed URLs)
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SSL=true
# PG_APPLICATION_NAME=arucase-backend

# Session safeguards (milliseconds; applied per pooled connection)
# STATEMENT_TIMEOUT_MS=60000
# IDLE_IN_TRANSACTION_TIMEOUT_MS=120000
# PG_LOCK_TIMEOUT_MS=30000

# Optional: cap concurrent DB requests (0 = unlimited). Keep below POOL_MAX.
# DB_MAX_CONCURRENT_QUERIES=80

# Backups: node scripts/backupDatabase.js or npm run db:backup --prefix backend
# BACKUP_VERIFY=1
# BACKUP_RETENTION_DAYS=14
# BACKUP_MAX_FILES=40
# PG_RESTORE_JOBS=4

# Required for initDatabase / seedAdminUser (choose a strong password)
SEED_ADMIN_PASSWORD=

# Optional: one-off scripts
# LOCAL_DATABASE_URL=postgresql://...
# RAILWAY_DATABASE_URL=postgresql://...
# MYSQL_PASSWORD=           # legacy MySQL → PG migration only
# ADMIN_PASSWORD=           # backend/scripts/createAdmin.js
# TEST_LOGIN_PASSWORD=      # backend/test_auth_flow.js, test_august_api_direct.js
# DEV_AUTO_LOGIN_JWT=       # backend/auto_login_fix.js (regenerate after running script)
